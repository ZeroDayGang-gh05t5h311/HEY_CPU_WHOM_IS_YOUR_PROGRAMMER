#!/usr/bin/python3
"""
Hello to the next world on this portion of the challenage as you don't need to worry about layers of abstraction
"""
class tmp:
	def helloworld():
		print("Hello world!")
	def speak(argout):
		if type(argout) == "str":
			print("Hello world...\nCPU SAYS: %s" %(argout))
		elif type(argout) == "int":
			print("Hello world...\nCPU SAY: %i"%(argout))
tmp.helloworld()
