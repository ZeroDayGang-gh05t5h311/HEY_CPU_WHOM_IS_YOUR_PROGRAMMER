7. Functions
Defining Functions

def greet(name):
    """Function with a docstring"""
    return f"Hello, {name}!"

greet("Alice")  # "Hello, Alice!"

Arguments

def add(a, b=0, *args, **kwargs):
    """a and b are normal, *args is extra positional, **kwargs is extra keyword"""
    print("a:", a)
    print("b:", b)
    print("args:", args)
    print("kwargs:", kwargs)
    return a + b + sum(args)

add(1, 2, 3, 4, x=10, y=20)

Lambda Functions

square = lambda x: x**2
square(5)  # 25

# Sorting with lambda
lst = [(1,2),(3,1),(5,0)]
lst.sort(key=lambda x: x[1])  # Sort by second element

