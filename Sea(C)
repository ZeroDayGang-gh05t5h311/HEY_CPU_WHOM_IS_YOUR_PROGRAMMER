                        POINTER BASICS
====================================================================
A pointer is a variable that stores a memory address.
Syntax:
    type *pointerName;
Example:
    int *p;
Meaning:
    p stores the address of an int.
Operators:
    &  -> address-of
    *  -> dereference (access value at address)
void pointerBasics() {
    printf("=== POINTER BASICS ===\n");
    int x = 10;
    int *ptr = &x;  // ptr stores address of x
    printf("Value of x: %d\n", x);
    printf("Address of x: %p\n", (void*)&x);
    printf("ptr stores: %p\n", (void*)ptr);
    printf("Value at ptr (*ptr): %d\n", *ptr);
    // Modify through pointer
    *ptr = 20;
    printf("Modified x through pointer: %d\n\n", x);
}
====================================================================
                    POINTER ARITHMETIC
====================================================================
When you add to a pointer:
    ptr + 1
It moves by sizeof(type).
If ptr is int*:
    ptr + 1 moves 4 bytes (typically)
NOT 1 byte.
void pointerArithmetic() {
    printf("=== POINTER ARITHMETIC ===\n");
    int arr[3] = {10, 20, 30};
    int *ptr = arr;  // same as &arr[0]
    printf("arr[0]: %d\n", *ptr);
    printf("arr[1]: %d\n", *(ptr + 1));
    printf("arr[2]: %d\n\n", *(ptr + 2));
}
====================================================================
                    STACK VS HEAP
====================================================================
STACK:
- int x;
- Automatically freed
- Fast
- Limited size
HEAP:
- malloc()
- Must call free()
- Flexible size
- Risk of leaks
void stackVsHeap() {
    printf("=== STACK VS HEAP ===\n");
    int stackVar = 5;  // Stored on stack
    int *heapVar = malloc(sizeof(int));  // Stored on heap
    if (heapVar == NULL) {
        printf("Memory allocation failed!\n");
        return;
    }
    *heapVar = 100;
    printf("Stack variable value: %d\n", stackVar);
    printf("Heap variable value: %d\n", *heapVar);
    free(heapVar);  // Always free heap memory!
    printf("Heap memory freed.\n\n");
}
