    for (int i = 0; i < 3; i++) array[i] = i * 10;

    printf("Original array:\n");
    for (int i = 0; i < 3; i++) printf("%d ", array[i]);

    array = realloc(array, 5 * sizeof(int));
    printf("\nResized array (first 3 values preserved):\n");
    for (int i = 0; i < 3; i++) printf("%d ", array[i]);

    free(array);
    printf("\nMemory freed.\n\n");
}
